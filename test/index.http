### Añadir datos de onboarding
PUT {{baseURL}}/api/user/register
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJfaWQiOiI2OWQzZTU2MTliNTM4YzQzNzgzNzc1M2MiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3NzU0OTQ1NDYsImV4cCI6MTc3NTQ5NTQ0Nn0.ModlKM4D3ZhHZ4v6S6sKd4UtfFiBDCohZM-H6mZrbLk
Content-Type: application/json

{
    "name": "Jaime3",
    "lastName": "Castellano Cubells",
    "nif": "12345678A"
}

### Crear nueva compañía (no existe CIF)
PATCH {{baseURL}}/api/user/company
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJfaWQiOiI2OWQzOGNiMzMwY2NlZmZjNGZiZDZhOWIiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3NzU0OTM3MTUsImV4cCI6MTc3NTQ5NDYxNX0.fOJvZfdgsSmo0PzzdpsaCFGImxjiI10o_fCmyJk72h8
Content-Type: application/json

{
    "name": "Empresa de Jaime",
    "cif": "B12345678",
    "address": {
        "street": "Calle Falsa",
        "number": "123",
        "postal": "28080",
        "city": "Madrid",
        "province": "Madrid"
    },
    "isFreelance": false
}


